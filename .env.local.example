# ──────────────────────────────────────────────────────────────────────────────
# Supabase
# Отримайте у: https://supabase.com → Project Settings → API
# ──────────────────────────────────────────────────────────────────────────────

# URL проєкту (вкладка "Project URL")
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# Service Role Key — повний доступ, обходить RLS.
# Використовується ТІЛЬКИ на сервері (API routes, Server Components).
# НЕ кладіть у NEXT_PUBLIC_ змінні!
# Знайдете у: Project Settings → API → "service_role" (secret)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ──────────────────────────────────────────────────────────────────────────────
# Як застосувати:
#   cp .env.local.example .env.local
#   # Відредагуйте .env.local — вставте реальні значення
#   npm run dev
# ──────────────────────────────────────────────────────────────────────────────
